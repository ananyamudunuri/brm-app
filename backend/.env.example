# Environment
ENVIRONMENT=development
DEBUG=True

# Database (will be overridden by Secret Manager in production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/crmdb

# JWT (for local development only)
JWT_SECRET_KEY=your-local-dev-secret-key-min-64-chars-here-change-this
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# GCP
GOOGLE_CLOUD_PROJECT=PROJECT-A

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080